<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>L33t Store</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <main class="home">
    <section class="home-hero">
      <p class="eyebrow">Express + EJS security training</p>
      <h1>L33t Store</h1>
      <p>A polished e-commerce lab with matching vulnerable and secure workflows for practicing real web security bugs.</p>
      <div class="actions">
        <a class="button danger" href="/vulnerable/products">Enter vulnerable store</a>
        <a class="button good" href="/secure/products">Enter secure store</a>
      </div>
    </section>
    <section class="notes home-grid">
      <div>
        <h2>Demo accounts</h2>
        <p><code>wiener:peter</code></p>
        <p><code>carlos:montoya</code></p>
      </div>
      <div>
        <h2>Lab coverage</h2>
        <p>Business logic, authentication, 2FA, remember-me cookies, and CSRF side by side.</p>
      </div>
    </section>
  </main>
</body>
</html>
