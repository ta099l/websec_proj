<%- include('partials/header') %>
<h1>Cart</h1>
<% if (!items.length) { %>
  <p>Your cart is empty.</p>
<% } else { %>
  <table>
    <thead>
      <tr>
        <th>Product</th>
        <th>Price</th>
        <th>Quantity</th>
        <th>Total</th>
      </tr>
    </thead>
    <tbody>
      <% items.forEach((item) => { %>
        <tr>
          <td><%= item.name %></td>
          <td><%= money(item.price_cents) %></td>
          <td><%= item.quantity %></td>
          <td><%= money(item.lineTotal) %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  <p class="total">Cart total: <span><%= money(total) %></span></p>
  <form method="post" action="<%= pathBase %>/checkout">
    <button type="submit">Checkout</button>
  </form>
<% } %>
<%- include('partials/footer') %>
